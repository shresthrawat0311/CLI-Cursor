import 'dotenv/config'
import { OpenAI } from 'openai'

const client = new OpenAI({
    baseURL : "https://api.groq.com/openai/v1",
    apiKey : process.env.GROQ_API_KEY
})
const systemPrompt = `You are a thinking model. You think and think before giving an ouput. You are supposed to give output in output JSON format. in the output, dont include any markdowns, or backticks, for the output you give, its first character must be { and its last character must be }. also do not include any conversational tex like "hey how are you" or "do you need any help"/ You have only 3 modes: START, THINK and OUTPUT. you are supposed to give only one step at a time and wait for the next step
                    Output JSON Format:
                    {"Step" : "START | THINK | OUTPUT", "content" : "string"}
                    Below is an example:
                    User : what is 5 * 4 + 2 - 1?
                    Assistant : {"Step" : "START", "content" : "I have recognized that the user has asked me to solve a mathematical expression"}
                    Assistant : {"Step" : "THINK", "content" : "I have recognized that this is a BODMAS question"}
                    Assistant : {"Step" : "THINK", "content" : "To solve this, we firstly need to solve the multiplication and division before addition and subtraction"}
                    Assistant : {"Step" : "THINK", "content" : "I have tracked that in this question there is no division, but only mutiplication, so we will start with it"}
                    Assistant : {"Step" : "THINK", "content" : "5 * 4 gives 20, now the equation remains 20 + 2 - 1"}
                    Assistant : {"Step" : "THINK", "content" : "Solving this gives 21"}
                    Assistant : {"Step" : "OUTPUT", "content" : "Answer is 21"}
                    `
const messages = [
    {role : "system", content : systemPrompt},
    {role : "user", content : "what is mitochondria of a cell"}
]
async function main(){
    while(true){
    const response = await client.chat.completions.create({
        model : "llama-3.3-70b-versatile",
        messages : messages
    })
    
    try{
        const rawJson = JSON.parse(response.choices[0].message.content)
        messages.push({
            role : "assistant", content : JSON.stringify(rawJson)
        })
        if(rawJson.Step == "START"){
            console.log("✨ " + rawJson.content)
            messages.push({role: "user", content: "you have completed this step, now move on to the next step"})
            continue
        }
        if(rawJson.Step == "THINK"){
            console.log("🧠 " + rawJson.content)
            messages.push({role: "user", content: "you have completed this step, now move on to the next step"})
            continue
        }
        if(rawJson.Step == "OUTPUT"){
            console.log("😎 " + rawJson.content)
            break
        }
    }
    catch{
        messages.push({role: "user", content: "AI didn't respond with correct JSON format, strictly use the correct JSON format"})
        continue
    }
    
    }
}

main()
